{
  "schema_version": "1.0.0",
  "design_id": "hysteretic_threshold_detector_3v0_2v0_lm393",
  "design_type": "block",
  "name": "3.0 V / 2.0 V Hysteretic Threshold Detector",
  "description": "Comparator-based non-inverting Schmitt trigger that switches LOW to HIGH when the input rises above approximately 3.0 V and HIGH to LOW when the input falls below approximately 2.0 V. Uses one section of an LM393, a 2.50 V reference divider, positive feedback, an output pull-up resistor, and local supply decoupling.",
  "category": "analog",
  "tags": [
    "analog",
    "comparator",
    "lm393",
    "schmitt-trigger",
    "hysteresis",
    "threshold-detector",
    "3.0v-rising",
    "2.0v-falling",
    "open-collector"
  ],
