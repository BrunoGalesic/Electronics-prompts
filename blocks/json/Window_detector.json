{
"name": "VIN",
"direction": "input",
"signal_type": "analog",
"required": true,
"maps_to_net": "VIN",
"description": "Analog input to be tested against the 2.0 V and 3.0 V window thresholds."
},
{
"name": "OUT",
"direction": "output",
"signal_type": "digital",
"required": true,
"maps_to_net": "OUT",
"description": "Window comparator output; HIGH only when VIN is between the lower and upper thresholds."
},
{
"name": "+5V",
"direction": "input",
"signal_type": "power",
"required": true,
"maps_to_net": "+5V",
"description": "Positive supply rail for the comparator and reference divider."
},
{
"name": "GND",
"direction": "input",
"signal_type": "ground",
"required": true,
"maps_to_net": "GND",
"description": "Ground reference and return path."
}
],
