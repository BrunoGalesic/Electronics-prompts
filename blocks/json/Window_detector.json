{
"schema_version": "1.0.0",
"design_id": "window_comparator_2v_3v_lm393",
"design_type": "block",
"name": "2V-to-3V Window Comparator",
"description": "Reusable analog block implementing a window comparator with a lower threshold near 2.0 V and an upper threshold near 3.0 V. The output is HIGH only when the input voltage is between the two thresholds and LOW otherwise.",
"category": "analog",
"tags": [
"window-comparator",
"comparator",
"lm393",
"threshold-detection",
"analog",
"single-supply",
"open-collector"
],
